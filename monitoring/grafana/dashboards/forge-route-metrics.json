{
  "schemaVersion": 36,
  "title": "Forge - Route Metrics",
  "tags": ["forge", "http", "routes"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Total RPS",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(forge_request_total{status!=\"exception\"}[1m]))", "legendFormat": "rps" }
      ]
    },
    {
      "type": "bargauge",
      "title": "Top Routes by RPS",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "options": { "displayMode": "gradient", "orientation": "horizontal" },
      "targets": [
        { "expr": "topk(10, sum by (route) (rate(forge_request_total{status!=\"exception\"}[5m])))", "legendFormat": "{{route}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate by Route (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "100 * sum by (route) (rate(forge_request_total{status=~\"5..\"}[5m])) / sum by (route) (rate(forge_request_total{status!=\"exception\"}[5m]))", "legendFormat": "{{route}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "type": "timeseries",
      "title": "p95 Latency by Route (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(forge_request_duration_ms_bucket[5m])))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "type": "bargauge",
      "title": "Top Routes by Egress (B/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": { "displayMode": "gradient", "orientation": "horizontal" },
      "targets": [
        { "expr": "topk(10, sum by (route) (rate(forge_response_bytes_total[5m])))", "legendFormat": "{{route}}" }
      ]
    },
    {
      "type": "table",
      "title": "Route Health (RPS, Error %, p95)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "transformations": [
        { "id": "merge", "options": {} }
      ],
      "targets": [
        { "refId": "A", "expr": "sum by (route) (rate(forge_request_total{status!=\"exception\"}[5m]))", "legendFormat": "rps {{route}}" },
        { "refId": "B", "expr": "100 * sum by (route) (rate(forge_request_total{status=~\"5..\"}[5m])) / sum by (route) (rate(forge_request_total{status!=\"exception\"}[5m]))", "legendFormat": "err% {{route}}" },
        { "refId": "C", "expr": "histogram_quantile(0.95, sum by (le, route) (rate(forge_request_duration_ms_bucket[5m])))", "legendFormat": "p95 {{route}}" }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "route",
        "type": "query",
        "datasource": null,
        "query": "label_values(forge_request_total, route)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "annotations": { "list": [] }
}
