{
  "title": "LLM Costs & Token Usage",
  "uid": "llm-costs",
  "version": 1,
  "tags": ["llm", "costs", "tokens"],
  "timezone": "",
  "schemaVersion": 38,
  "refresh": "30s",
  "liveNow": true,
  "panels": [
    {
      "title": "Total Token Consumption",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(metasop_total_tokens[5m])",
          "legendFormat": "Tokens/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "axisLabel": "Tokens/sec",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "title": "Token Usage by Model",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "metasop_model_total_tokens",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "right"},
        "pieType": "donut"
      }
    },
    {
      "title": "Average Tokens per Step",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "metasop_avg_tokens_per_executed_step",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5000},
              {"color": "red", "value": 10000}
            ]
          }
        }
      },
      "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "title": "Cache Hit Rate (Cost Savings)",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "(metasop_cache_hits / (metasop_cache_hits + metasop_cache_stores)) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 30},
              {"color": "green", "value": 50}
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    }
  ],
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {}
}

