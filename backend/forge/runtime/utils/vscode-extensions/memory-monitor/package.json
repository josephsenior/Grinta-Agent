{
  "name": "Forge-memory-monitor",
  "displayName": "Forge Memory Monitor",
  "description": "A VSCode extension for monitoring system and process memory usage",
  "version": "0.1.0",
  "publisher": "forge",
  "engines": {
    "vscode": "^1.98.2"
  },
  "categories": [
    "Other",
    "Monitoring"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "Forge-memory-monitor.startMemoryMonitor",
        "title": "Start Memory Monitor"
      },
      {
        "command": "Forge-memory-monitor.stopMemoryMonitor",
        "title": "Stop Memory Monitor"
      },
      {
        "command": "Forge-memory-monitor.showMemoryDetails",
        "title": "Show Memory Details"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "Forge-memory-monitor.startMemoryMonitor",
          "group": "forge"
        },
        {
          "command": "Forge-memory-monitor.stopMemoryMonitor",
          "group": "forge"
        },
        {
          "command": "Forge-memory-monitor.showMemoryDetails",
          "group": "forge"
        }
      ]
    }
  }
}
