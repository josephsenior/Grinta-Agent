{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://forge.ai/schemas/metasop/pm_spec.json",
  "title": "Product Manager Specification Artifact",
  "description": "Enhanced Product Manager artifact schema matching premium MetaSOP profiles with detailed user stories, acceptance criteria, and planning information",
  "type": "object",
  "required": ["user_stories", "acceptance_criteria"],
  "properties": {
    "user_stories": {
      "type": "array",
      "description": "Collection of user stories in structured format or as strings",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "description": "User story as a string in 'As a... I want... so that...' format",
            "minLength": 10
          },
          {
            "type": "object",
            "description": "Structured user story with detailed metadata",
            "required": ["title"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for the user story",
                "pattern": "^US-[0-9]+$"
              },
              "title": {
                "type": "string",
                "description": "Short, descriptive title of the user story",
                "minLength": 5,
                "maxLength": 200
              },
              "story": {
                "type": "string",
                "description": "Full user story in 'As a [user] I want [feature] so that [benefit]' format",
                "minLength": 20
              },
              "description": {
                "type": "string",
                "description": "Detailed description of the user story and context"
              },
              "priority": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"],
                "description": "Priority level for implementation"
              },
              "story_points": {
                "type": "integer",
                "description": "Estimated complexity in story points (Fibonacci: 1, 2, 3, 5, 8, 13)",
                "minimum": 1,
                "maximum": 13
              },
              "acceptance_criteria": {
                "type": "array",
                "description": "Specific, testable conditions that must be met",
                "items": {
                  "type": "string",
                  "minLength": 10
                }
              },
              "dependencies": {
                "type": "array",
                "description": "IDs of other user stories this depends on",
                "items": {
                  "type": "string",
                  "pattern": "^US-[0-9]+$"
                }
              },
              "estimated_complexity": {
                "type": "string",
                "enum": ["small", "medium", "large"],
                "description": "T-shirt sizing for quick estimation"
              },
              "user_value": {
                "type": "string",
                "description": "Why this matters to users - the business value",
                "minLength": 10
              }
            }
          }
        ]
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "description": "Overall acceptance criteria for the feature",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "description": "Acceptance criterion as a string",
            "minLength": 10
          },
          {
            "type": "object",
            "description": "Structured acceptance criterion",
            "required": ["criteria"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier",
                "pattern": "^AC-[0-9]+$"
              },
              "title": {
                "type": "string",
                "description": "Short title of the criterion"
              },
              "description": {
                "type": "string",
                "description": "Context and details"
              },
              "criteria": {
                "type": "string",
                "description": "The actual testable criterion",
                "minLength": 10
              }
            }
          }
        ]
      }
    },
    "ui_multi_section": {
      "type": "boolean",
      "description": "Set true when feature has multiple distinct UI sections requiring a layout plan",
      "default": false
    },
    "ui_sections": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "description": "Approximate count of distinct UI sections/panels"
    },
    "assumptions": {
      "type": "array",
      "description": "Explicit assumptions made during planning",
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "out_of_scope": {
      "type": "array",
      "description": "Features explicitly excluded from this specification",
      "items": {
        "type": "string",
        "minLength": 5
      }
    }
  },
  "examples": [
    {
      "user_stories": [
        {
          "id": "US-001",
          "title": "User Registration",
          "story": "As a new user I want to create an account so that I can access the platform",
          "priority": "high",
          "story_points": 5,
          "estimated_complexity": "medium",
          "user_value": "Enables users to access personalized features",
          "dependencies": [],
          "acceptance_criteria": [
            "User can enter email and password",
            "Password validation includes minimum length of 8 characters",
            "Confirmation email is sent after registration"
          ]
        }
      ],
      "acceptance_criteria": [
        "All user stories must pass QA testing",
        "UI must be responsive on mobile and desktop",
        "Performance: Page load time < 2 seconds"
      ],
      "ui_multi_section": true,
      "ui_sections": 3,
      "assumptions": [
        "Users have valid email addresses",
        "Email service is configured and operational"
      ],
      "out_of_scope": [
        "Social media login integration",
        "Two-factor authentication"
      ]
    }
  ]
}
