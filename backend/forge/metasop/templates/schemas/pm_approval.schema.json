{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["approved", "comments"],
  "properties": {
    "approved": {
      "type": "boolean",
      "description": "Whether the implementation is approved for merge"
    },
    "comments": {
      "type": "string",
      "description": "Product Manager's comments on the implementation"
    },
    "concerns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of concerns or issues that need to be addressed (if any)"
    },
    "quality_rating": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Overall quality rating (1-5 scale)"
    },
    "recommendation": {
      "type": "string",
      "enum": ["merge", "revise", "reject"],
      "description": "Recommended next action"
    }
  }
}

