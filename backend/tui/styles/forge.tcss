"""Forge TUI stylesheet — Textual CSS.

Defines the visual identity: dark theme, panel layout, message styling.
"""

/* ── Global ─────────────────────────────────────────────── */

Screen {
    background: $surface;
}

/* ── Home screen ────────────────────────────────────────── */

#home-container {
    height: 100%;
    padding: 1 2;
}

#logo-header {
    height: 3;
    content-align: center middle;
    text-style: bold;
    color: $accent;
}

#conversation-list {
    height: 1fr;
    border: round $primary;
    padding: 0 1;
}

#new-conversation-bar {
    height: 3;
    dock: bottom;
    padding: 0 1;
}

#new-conversation-input {
    width: 1fr;
}

.conversation-item {
    height: 3;
    padding: 0 1;
    border-bottom: hkey $surface-lighten-2;
}

.conversation-item:hover {
    background: $surface-lighten-1;
}

.conversation-item:focus {
    background: $accent 20%;
}

.conversation-title {
    width: 1fr;
    text-style: bold;
}

.conversation-meta {
    color: $text-muted;
    text-align: right;
    width: auto;
}

/* ── Chat screen ────────────────────────────────────────── */

#chat-container {
    height: 100%;
}

#message-panel {
    height: 1fr;
    overflow-y: auto;
    padding: 0 1;
}

#input-area {
    height: auto;
    max-height: 8;
    dock: bottom;
    padding: 0 1;
    border-top: hkey $primary;
}

#chat-input {
    width: 1fr;
}

/* ── Messages ───────────────────────────────────────────── */

.user-message {
    margin: 1 0 0 4;
    padding: 0 1;
    background: $primary 15%;
    border-left: tall $primary;
}

.assistant-message {
    margin: 1 4 0 0;
    padding: 0 1;
    background: $surface-lighten-1;
    border-left: tall $accent;
}

.system-message {
    margin: 1 2;
    padding: 0 1;
    color: $text-muted;
    text-style: italic;
    text-align: center;
}

/* ── Action cards ───────────────────────────────────────── */

.action-card {
    margin: 1 0;
    padding: 0 1;
    border: round $warning;
    height: auto;
}

.action-card-header {
    text-style: bold;
    color: $warning;
}

.action-card-body {
    padding: 0 2;
}

.observation-card {
    margin: 0 0 1 2;
    padding: 0 1;
    border: round $success;
    height: auto;
}

/* ── Confirmation bar ───────────────────────────────────── */

#confirmation-bar {
    height: 3;
    dock: bottom;
    padding: 0 1;
    background: $warning 20%;
    border-top: hkey $warning;
    display: none;
}

#confirmation-bar.visible {
    display: block;
}

.confirm-btn {
    margin: 0 1;
}

/* ── Status bar ─────────────────────────────────────────── */

#status-bar {
    height: 1;
    dock: bottom;
    background: $primary-darken-2;
    color: $text;
    padding: 0 1;
}

.status-agent-state {
    width: auto;
    text-style: bold;
}

.status-model {
    width: 1fr;
    text-align: center;
    color: $text-muted;
}

.status-cost {
    width: auto;
    text-align: right;
}

/* ── Settings screen ────────────────────────────────────── */

#settings-container {
    height: 100%;
    padding: 1 2;
}

.settings-group {
    margin: 1 0;
    padding: 1 2;
    border: round $primary;
    height: auto;
}

.settings-label {
    width: 20;
    text-style: bold;
}

.settings-value {
    width: 1fr;
}

/* ── Diff viewer ────────────────────────────────────────── */

#diff-container {
    height: 100%;
    padding: 0 1;
}

.diff-add {
    color: $success;
}

.diff-remove {
    color: $error;
}

.diff-header {
    text-style: bold;
    color: $accent;
    padding: 1 0;
}

/* ── Empty states ───────────────────────────────────────── */

.empty-state {
    height: 100%;
    content-align: center middle;
    color: $text-muted;
    text-style: italic;
}
