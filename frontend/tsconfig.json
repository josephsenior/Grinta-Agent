{
  "extends": "..\/tsconfig.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "es2022"],
    "target": "es2022",
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "rootDirs": [".", "./.react-router/types"],
    "baseUrl": ".",
    "types": ["@react-router/node", "vite/client", "@testing-library/jest-dom", "vitest/globals", "jest"],
    "paths": {
      "test-utils": ["./test-utils"],
      "#/*": ["./src/*"],
      "./+types/*": [
        "./.react-router/types/src/routes/+types/*",
        "./src/routes/+types/*"
      ]
    },
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx",
    "types/**/*.d.ts",
    "vitest.setup.ts",
    "vite.config.ts",
    "vite.config.prod.ts",
    "**/.server/**/*.ts",
    "**/.server/**/*.tsx",
    "**/.client/**/*.ts",
    "**/.client/**/*.tsx",
    ".react-router/types/**/*"
  ],
  "exclude": []
}
