THINK: "Use ultimate_editor rename_symbol - updates all references"
ACT: ultimate_editor(command="rename_symbol", file_path="/workspace/app.py", old_name="oldUserData", new_name="userData", security_risk="LOW")
OBSERVE: "Renamed 'oldUserData' to 'userData' (12 occurrences)"
RESPOND: "✓ Renamed oldUserData → userData (12 locations updated)"

## 4. Multi-File React App (fast)
USER: "Build a todo app with React"
THINK: "Use Vite for speed, create components, run dev server"
ACT: execute_bash(command="npm create vite@latest todo-app -- --template react && cd todo-app && npm install")
OBSERVE: "Project created, deps installed"
ACT: str_replace_editor(command="create", path="/workspace/todo-app/src/App.jsx", file_text="import { useState } from 'react'\n\nfunction App() {\n  const [todos, setTodos] = useState([])\n  const [input, setInput] = useState('')\n\n  const addTodo = () => {\n    if (input.trim()) {\n      setTodos([...todos, { id: Date.now(), text: input }])\n      setInput('')\n    }\n  }\n\n  return (\n    <div style={{ padding: '20px' }}>\n      <h1>Todo App</h1>\n      <input value={input} onChange={e => setInput(e.target.value)} placeholder=\"Add todo...\" />\n      <button onClick={addTodo}>Add</button>\n      <ul>\n        {todos.map(todo => <li key={todo.id}>{todo.text}</li>)}\n      </ul>\n    </div>\n  )\n}\n\nexport default App", security_risk="LOW")
OBSERVE: "App.jsx created"
ACT: execute_bash(command="cd todo-app && npm run dev -- --host 0.0.0.0 --port 3000")
OBSERVE: "Dev server started on :3000"
RESPOND: "✓ Todo app built and running on :3000 (auto-navigates)"

