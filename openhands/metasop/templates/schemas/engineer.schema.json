{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://forge.ai/schemas/metasop/engineer.json",
  "title": "Engineer Planning Blueprint",
  "description": "Engineer artifact schema for implementation planning, file structure design, dependencies, and setup instructions. Contains the PLAN, not actual code - CodeAct will handle implementation.",
  "type": "object",
  "required": ["artifact_path", "tests_added", "run_results", "file_structure", "implementation_plan", "dependencies"],
  "properties": {
    "artifact_path": {
      "type": "string",
      "description": "Path to the main artifact or implementation directory",
      "minLength": 1
    },
    "tests_added": {
      "type": "boolean",
      "description": "Whether tests have been added for the implementation"
    },
    "run_results": {
      "type": "object",
      "description": "Commands and setup instructions for running the application",
      "properties": {
        "setup_commands": {
          "type": "array",
          "description": "Commands to set up the environment",
          "items": {
            "type": "string"
          }
        },
        "test_commands": {
          "type": "array",
          "description": "Commands to run tests",
          "items": {
            "type": "string"
          }
        },
        "dev_commands": {
          "type": "array",
          "description": "Commands to start development server",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "files": {
      "type": "array",
      "description": "List of files created or modified (flat structure)",
      "items": {
        "$ref": "#/definitions/FileNode"
      }
    },
    "file_changes": {
      "type": "array",
      "description": "Alias for files",
      "items": {
        "$ref": "#/definitions/FileNode"
      }
    },
    "components": {
      "type": "array",
      "description": "List of components created",
      "items": {
        "$ref": "#/definitions/FileNode"
      }
    },
    "file_structure": {
      "$ref": "#/definitions/FileNode",
      "description": "Complete recursive file/folder structure"
    },
    "implementation_plan": {
      "type": "string",
      "description": "Multi-phase development plan with milestones",
      "minLength": 50
    },
    "plan": {
      "type": "string",
      "description": "Alias for implementation_plan"
    },
    "dependencies": {
      "type": "array",
      "description": "List of npm/pip/etc packages required with versions",
      "items": {
        "type": "string"
      }
    },
    "technical_decisions": {
      "type": "array",
      "description": "Key technical decisions and their rationale",
      "items": {
        "type": "object",
        "properties": {
          "decision": {
            "type": "string",
            "description": "The technical decision made"
          },
          "rationale": {
            "type": "string",
            "description": "Why this decision was made"
          },
          "alternatives": {
            "type": "string",
            "description": "What alternatives were considered"
          }
        },
        "required": ["decision", "rationale"]
      }
    },
    "environment_variables": {
      "type": "array",
      "description": "Required environment variables and their purposes",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Environment variable name"
          },
          "description": {
            "type": "string",
            "description": "What this variable is used for"
          },
          "example": {
            "type": "string",
            "description": "Example value"
          }
        },
        "required": ["name", "description"]
      }
    }
  },
  "definitions": {
    "FileNode": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "File or folder name"
        },
        "path": {
          "type": "string",
          "description": "Full path to the file or folder"
        },
        "file": {
          "type": "string",
          "description": "Alias for name"
        },
        "type": {
          "type": "string",
          "enum": ["file", "folder", "directory"],
          "description": "Whether this is a file or folder"
        },
        "description": {
          "type": "string",
          "description": "Purpose of this file/folder",
          "minLength": 5
        },
        "children": {
          "type": "array",
          "description": "Child files/folders (for recursive structure)",
          "items": {
            "$ref": "#/definitions/FileNode"
          }
        }
      },
      "required": ["name"]
    }
  },
  "examples": [
    {
      "artifact_path": "src/features/tasks",
      "tests_added": true,
      "run_results": {
        "setup_commands": [
          "npm install",
          "cp .env.example .env"
        ],
        "test_commands": [
          "npm test",
          "npm run test:coverage"
        ],
        "dev_commands": [
          "npm run dev"
        ]
      },
      "file_structure": {
        "name": "src",
        "type": "folder",
        "description": "Source code root",
        "children": [
          {
            "name": "components",
            "type": "folder",
            "description": "React components",
            "children": [
              {
                "name": "TaskList.tsx",
                "type": "file",
                "description": "Main task list component with filtering"
              },
              {
                "name": "TaskItem.tsx",
                "type": "file",
                "description": "Individual task card with actions"
              }
            ]
          },
          {
            "name": "api",
            "type": "folder",
            "description": "API client functions",
            "children": [
              {
                "name": "tasks.ts",
                "type": "file",
                "description": "Task CRUD API functions"
              }
            ]
          },
          {
            "name": "__tests__",
            "type": "folder",
            "description": "Test files",
            "children": [
              {
                "name": "TaskList.test.tsx",
                "type": "file",
                "description": "Unit tests for TaskList component"
              }
            ]
          }
        ]
      },
      "implementation_plan": "## Phase 1: Core Components\n\n1. Create TaskList component with filtering\n2. Implement TaskItem with edit/delete\n3. Add loading and error states\n\n## Phase 2: API Integration\n\n1. Set up API client\n2. Implement CRUD operations\n3. Add optimistic updates\n\n## Phase 3: Testing & Polish\n\n1. Write unit tests\n2. Add integration tests\n3. Performance optimization"
    }
  ]
}
