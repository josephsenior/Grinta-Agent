{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://forge.ai/schemas/metasop/architect.json",
  "title": "Architect Design Artifact",
  "description": "Enhanced Architect artifact schema with comprehensive design documentation, API specifications, database schema, technology stack, and scalability considerations",
  "type": "object",
  "required": ["design_doc", "apis", "decisions", "next_tasks"],
  "properties": {
    "design_doc": {
      "type": "string",
      "pattern": ".*## .*",
      "minLength": 100,
      "description": "Comprehensive architectural design document with markdown sections for Overview, Components, Data Flow, Security, and Deployment considerations"
    },
    "apis": {
      "type": "array",
      "minItems": 1,
      "description": "List of REST API endpoints with detailed specifications",
      "items": {
        "type": "object",
        "required": ["path", "method", "description"],
        "properties": {
          "path": {
            "type": "string",
            "description": "API endpoint path (e.g., /api/v1/users, /api/v1/todos/{id})",
            "pattern": "^/.*"
          },
          "endpoint": {
            "type": "string",
            "description": "Alias for path"
          },
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"],
            "description": "HTTP method for this endpoint"
          },
          "description": {
            "type": "string",
            "description": "Clear description of what this endpoint does",
            "minLength": 10
          },
          "request_schema": {
            "type": "object",
            "description": "Expected request body or query parameters schema"
          },
          "response_schema": {
            "type": "object",
            "description": "Expected response body schema"
          },
          "auth_required": {
            "type": "boolean",
            "description": "Whether authentication is required for this endpoint",
            "default": true
          },
          "rate_limit": {
            "type": "string",
            "description": "Rate limiting policy (e.g., '100 requests/minute')",
            "pattern": "^[0-9]+ requests/(second|minute|hour|day)$"
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "description": "Key architectural decisions with rationale",
      "items": {
        "type": "object",
        "required": ["decision", "reason", "tradeoffs"],
        "properties": {
          "decision": {
            "type": "string",
            "description": "The architectural decision made",
            "minLength": 10
          },
          "reason": {
            "type": "string",
            "description": "Why this decision was made and what benefits it provides",
            "minLength": 20
          },
          "tradeoffs": {
            "type": "string",
            "description": "What are the downsides or limitations of this decision",
            "minLength": 10
          },
          "alternatives": {
            "type": "array",
            "description": "Alternative options that were considered",
            "items": {
              "type": "string",
              "minLength": 5
            }
          }
        }
      }
    },
    "next_tasks": {
      "type": "array",
      "minItems": 1,
      "description": "Specific tasks for the engineering team to implement",
      "items": {
        "type": "object",
        "required": ["role", "task"],
        "properties": {
          "role": {
            "type": "string",
            "description": "The role responsible for this task",
            "enum": ["Engineer", "DevOps", "QA", "Designer", "Product Manager"]
          },
          "task": {
            "type": "string",
            "description": "Detailed task description with specific deliverables",
            "minLength": 20
          },
          "description": {
            "type": "string",
            "description": "Additional context and requirements"
          }
        }
      }
    },
    "database_schema": {
      "type": "object",
      "description": "Complete database schema design",
      "properties": {
        "tables": {
          "type": "array",
          "description": "Database tables with columns, indexes, and relationships",
          "items": {
            "type": "object",
            "required": ["name", "columns"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Table name",
                "pattern": "^[a-z_][a-z0-9_]*$"
              },
              "description": {
                "type": "string",
                "description": "Purpose of this table"
              },
              "columns": {
                "type": "array",
                "description": "Table columns",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["name", "type"],
                  "properties": {
                    "name": {
                      "type": "string",
                      "pattern": "^[a-z_][a-z0-9_]*$"
                    },
                    "type": {
                      "type": "string",
                      "description": "SQL data type"
                    },
                    "constraints": {
                      "type": "array",
                      "description": "Column constraints (PRIMARY KEY, NOT NULL, UNIQUE, etc.)",
                      "items": {
                        "type": "string"
                      }
                    },
                    "description": {
                      "type": "string"
                    }
                  }
                }
              },
              "indexes": {
                "type": "array",
                "description": "Database indexes for performance",
                "items": {
                  "type": "object",
                  "required": ["columns"],
                  "properties": {
                    "columns": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "minItems": 1
                    },
                    "type": {
                      "type": "string",
                      "enum": ["btree", "hash", "gin", "gist"],
                      "description": "Index type"
                    },
                    "reason": {
                      "type": "string",
                      "description": "Why this index is needed"
                    }
                  }
                }
              },
              "relationships": {
                "type": "array",
                "description": "Foreign key relationships",
                "items": {
                  "type": "object",
                  "required": ["type", "from", "to"],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["one-to-one", "one-to-many", "many-to-one", "many-to-many"]
                    },
                    "from": {
                      "type": "string",
                      "description": "Column in this table"
                    },
                    "to": {
                      "type": "string",
                      "description": "Referenced table.column"
                    },
                    "through": {
                      "type": "string",
                      "description": "Junction table for many-to-many"
                    },
                    "description": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "migrations_strategy": {
          "type": "string",
          "description": "Strategy for database migrations (e.g., Alembic, Flyway, manual)"
        }
      }
    },
    "technology_stack": {
      "type": "object",
      "description": "Technologies chosen for implementation",
      "properties": {
        "frontend": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Frontend frameworks and libraries (e.g., React, Vue, Tailwind)"
        },
        "backend": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Backend frameworks and languages (e.g., FastAPI, Django, Node.js)"
        },
        "database": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Database systems (e.g., PostgreSQL, MongoDB, Redis)"
        },
        "authentication": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Auth solutions (e.g., JWT, OAuth2, Auth0)"
        },
        "hosting": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Hosting and deployment platforms (e.g., AWS, Vercel, Docker)"
        },
        "other": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Additional tools and services"
        }
      }
    },
    "integration_points": {
      "type": "array",
      "description": "External services and APIs to integrate with",
      "items": {
        "type": "object",
        "required": ["service", "purpose"],
        "properties": {
          "service": {
            "type": "string",
            "description": "Name of the external service"
          },
          "purpose": {
            "type": "string",
            "description": "Why we're integrating with this service"
          },
          "api_docs": {
            "type": "string",
            "format": "uri",
            "description": "Link to API documentation"
          }
        }
      }
    },
    "security_considerations": {
      "type": "array",
      "description": "Security measures and best practices to implement",
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "scalability_approach": {
      "type": "object",
      "description": "Strategy for scaling the application",
      "properties": {
        "horizontal_scaling": {
          "type": "string",
          "description": "How the application will scale horizontally"
        },
        "database_scaling": {
          "type": "string",
          "description": "Database scaling strategy (sharding, read replicas, etc.)"
        },
        "caching_strategy": {
          "type": "string",
          "description": "Caching approach (Redis, CDN, etc.)"
        },
        "performance_targets": {
          "type": "string",
          "description": "Expected performance metrics"
        }
      }
    }
  },
  "examples": [
    {
      "design_doc": "## Overview\n\nTask management system with real-time collaboration...",
      "apis": [
        {
          "path": "/api/v1/tasks",
          "method": "GET",
          "description": "Retrieve all tasks for the authenticated user",
          "auth_required": true,
          "rate_limit": "100 requests/minute",
          "response_schema": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/Task"
            }
          }
        }
      ],
      "decisions": [
        {
          "decision": "Use PostgreSQL for data persistence",
          "reason": "ACID compliance, strong JSON support, excellent for relational data",
          "tradeoffs": "More complex setup than NoSQL, scaling requires planning",
          "alternatives": ["MongoDB", "MySQL", "SQLite"]
        }
      ],
      "next_tasks": [
        {
          "role": "Engineer",
          "task": "Implement user authentication using JWT tokens with 24-hour expiry"
        }
      ],
      "database_schema": {
        "tables": [
          {
            "name": "users",
            "description": "User accounts and authentication",
            "columns": [
              {
                "name": "id",
                "type": "UUID",
                "constraints": ["PRIMARY KEY"]
              },
              {
                "name": "email",
                "type": "VARCHAR(255)",
                "constraints": ["NOT NULL", "UNIQUE"]
              }
            ]
          }
        ]
      },
      "technology_stack": {
        "frontend": ["React 18", "Tailwind CSS", "TypeScript"],
        "backend": ["FastAPI", "Python 3.11", "SQLAlchemy"],
        "database": ["PostgreSQL 15", "Redis"],
        "authentication": ["JWT", "OAuth2"],
        "hosting": ["Docker", "AWS ECS", "CloudFront"]
      },
      "security_considerations": [
        "All API endpoints require authentication except /health and /login",
        "Passwords hashed with bcrypt (cost factor 12)",
        "Rate limiting on all endpoints",
        "SQL injection prevention via parameterized queries"
      ]
    }
  ]
}
