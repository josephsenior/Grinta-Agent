# ============================================================================
# Runtime Performance Optimization Configuration
# ============================================================================
# 
# This file contains environment variables for optimizing OpenHands runtime
# startup performance using a warm server pool strategy.
#
# PERFORMANCE IMPACT:
# - Without warm servers: ~60 second startup time
# - With warm servers: ~5 second startup time (90% improvement!)
#
# COST IMPACT:
# - Development: $0 (servers created on-demand)
# - Production: $7.50-22.50/month (2-3 warm servers)
# - ROI: Massive (better UX = higher conversion rates)
#
# ============================================================================

# ----------------------------------------------------------------------------
# WARM SERVER POOL CONFIGURATION
# ----------------------------------------------------------------------------

# Number of warm servers to pre-create at application startup
# These servers are fully initialized and ready to handle requests immediately
# 
# Recommended values:
# - Development/Testing: 0 (create on-demand, zero cost when idle)
# - Production (Low traffic): 1 (instant startup for first user)
# - Production (Medium traffic): 2-3 (handle concurrent requests)
INITIAL_NUM_WARM_SERVERS=0

# Desired number of warm servers to maintain in the pool
# System automatically creates new warm servers to maintain this count
# 
# Recommended values:
# - Development: 1 (create after first use, minimal cost)
# - Production (< 100 users/day): 1 ($7.50/month)
# - Production (100-1000 users/day): 2 ($15/month)
# - Production (1000+ users/day): 3 ($22.50/month)
DESIRED_NUM_WARM_SERVERS=1

# ----------------------------------------------------------------------------
# PRODUCTION CONFIGURATION EXAMPLES
# ----------------------------------------------------------------------------

# Example 1: Low Traffic Production (<100 users/day)
# Cost: ~$7.50/month
# Startup: ~5 seconds
# ────────────────────────────────────────
# INITIAL_NUM_WARM_SERVERS=1
# DESIRED_NUM_WARM_SERVERS=1

# Example 2: Medium Traffic Production (100-1000 users/day)
# Cost: ~$15/month
# Startup: ~5 seconds
# ────────────────────────────────────────
# INITIAL_NUM_WARM_SERVERS=2
# DESIRED_NUM_WARM_SERVERS=2

# Example 3: High Traffic Production (1000+ users/day)
# Cost: ~$22.50/month
# Startup: ~3-5 seconds
# ────────────────────────────────────────
# INITIAL_NUM_WARM_SERVERS=3
# DESIRED_NUM_WARM_SERVERS=3

# ----------------------------------------------------------------------------
# ADDITIONAL PERFORMANCE TUNING
# ----------------------------------------------------------------------------

# Plugin initialization timeout (seconds)
# Default: 120s (too slow for production)
# Recommended: 60s (faster without compromising reliability)
INIT_PLUGIN_TIMEOUT=60

# Bash session "no change" timeout (seconds)
# How long to wait for command output before considering it stuck
# Default: 30s
# Recommended: 10s (faster feedback, agent auto-responds to prompts now)
NO_CHANGE_TIMEOUT_SECONDS=10

# Skip dependency checks in production
# Dependencies are already validated during deployment
# Set to 1 to skip checks and reduce startup time by 5-10s
SKIP_DEPENDENCY_CHECK=1

# ----------------------------------------------------------------------------
# LOGGING & MONITORING
# ----------------------------------------------------------------------------

# Enable debug logging for runtime performance
# Set to 0 in production to reduce I/O overhead
DEBUG_RUNTIME=0

# Log level for runtime operations
# Options: DEBUG, INFO, WARNING, ERROR
# Recommended production: INFO
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# RESOURCE LIMITS
# ----------------------------------------------------------------------------

# Maximum memory per runtime instance (GB)
# Prevents runaway processes from consuming all resources
MAX_MEMORY_GB=4

# Maximum number of concurrent runtime instances
# Safety limit to prevent resource exhaustion
MAX_CONCURRENT_RUNTIMES=100

# ----------------------------------------------------------------------------
# DEPLOYMENT MODES
# ----------------------------------------------------------------------------

# Development Mode (Default)
# - No warm servers at startup (save resources)
# - Create 1 warm server after first use
# - Cost: $0 when idle, ~$7.50/month when active
# ────────────────────────────────────────
# INITIAL_NUM_WARM_SERVERS=0
# DESIRED_NUM_WARM_SERVERS=1
# SKIP_DEPENDENCY_CHECK=0
# DEBUG_RUNTIME=1

# Production Mode (Recommended for most deployments)
# - Pre-create 2 warm servers for instant startup
# - Maintain 2 warm servers for traffic handling
# - Cost: ~$15/month
# - Startup: ~5 seconds (90% improvement)
# ────────────────────────────────────────
# INITIAL_NUM_WARM_SERVERS=2
# DESIRED_NUM_WARM_SERVERS=2
# SKIP_DEPENDENCY_CHECK=1
# DEBUG_RUNTIME=0
# LOG_LEVEL=INFO

# High-Performance Mode (For high-traffic production)
# - Pre-create 3 warm servers for zero-wait startup
# - Maintain 3 warm servers for peak traffic
# - Cost: ~$22.50/month
# - Startup: ~3-5 seconds
# ────────────────────────────────────────
# INITIAL_NUM_WARM_SERVERS=3
# DESIRED_NUM_WARM_SERVERS=3
# SKIP_DEPENDENCY_CHECK=1
# DEBUG_RUNTIME=0
# LOG_LEVEL=WARNING
# MAX_CONCURRENT_RUNTIMES=200

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------

# 1. Warm servers are only created for LOCAL runtime mode
#    Docker and Remote runtimes have their own optimization strategies
#
# 2. Memory usage scales linearly: ~500MB-1GB per warm server
#    Monitor with: docker stats (Docker mode) or ps aux (Local mode)
#
# 3. Warm servers auto-terminate when no active conversations exist
#    No wasted resources when system is idle
#
# 4. Cost estimates based on AWS/GCP/Azure standard pricing
#    Actual costs may vary by provider and region
#
# 5. ROI calculation: If warm servers prevent 1 user/month from abandoning
#    due to slow startup, the feature pays for itself 10x over
#
# ----------------------------------------------------------------------------

